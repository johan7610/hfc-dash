<script>
(function () {
  const KEY = "scrollY";
const KEY_URL = "scrollURL";

function candidates() {
  const list = [];
  const shell = document.getElementById("appShell");
  const main = document.getElementById("appScroll");
  if (shell) list.push(shell);
  if (main) list.push(main);
  if (document.scrollingElement) list.push(document.scrollingElement);
  list.push(document.documentElement);
  list.push(document.body);
  return Array.from(new Set(list)).filter(Boolean);
}

function pickScroller() {
  const c = candidates();
  // Prefer: a scrollable element that is currently scrolled
  for (const el of c) {
    try {
      if ((el.scrollHeight - el.clientHeight) > 5 && el.scrollTop > 0) return el;
    } catch (e) {}
  }
  // Otherwise: any scrollable element
  for (const el of c) {
    try {
      if ((el.scrollHeight - el.clientHeight) > 5) return el;
    } catch (e) {}
  }
  return document.scrollingElement || document.documentElement;
}

function save() {
  try {
    const el = pickScroller();
    const y = (el && typeof el.scrollTop === "number") ? el.scrollTop : (window.scrollY || 0);
    sessionStorage.setItem(KEY_URL, location.pathname + location.search);
    sessionStorage.setItem(KEY, String(y || 0));
  } catch (e) {}
}

function restore() {
  try {
    const url = sessionStorage.getItem(KEY_URL);
    const y = sessionStorage.getItem(KEY);
    if (!url || y === null) return;

    if (url !== (location.pathname + location.search)) return;

    const yy = parseInt(y, 10) || 0;
    const els = candidates();

    const attempt = () => {
      for (const el of els) {
        try { if (el && typeof el.scrollTop === "number") el.scrollTop = yy; } catch (e) {}
      }
      try { window.scrollTo(0, yy); } catch (e) {}
    };

    attempt();
    setTimeout(attempt, 50);
    setTimeout(attempt, 200);
    setTimeout(attempt, 500);

    sessionStorage.removeItem(KEY_URL);
    sessionStorage.removeItem(KEY);
  } catch (e) {}
}

document.addEventListener("submit", (e) => {
  if (e.target && e.target.tagName === "FORM") save();
}, true);

document.addEventListener("click", (e) => {
  const btn = e.target.closest("button, input[type='submit']");
  if (btn && btn.form) save();
}, true);

window.addEventListener("pageshow", restore);
window.addEventListener("load", restore);
</script>
