      const y = sc ? sc.scrollTop : (window.scrollY || document.documentElement.scrollTop || 0);
      sessionStorage.setItem(KEY, JSON.stringify({ u: urlKey(), y: Math.max(0, parseInt(y, 10) || 0) }));
    } catch (e) {}
  }

  function restoreScroll() {
    try {
      const raw = sessionStorage.getItem(KEY);
      if (!raw) return;
      const data = JSON.parse(raw);
      if (!data || data.u !== urlKey()) return;

      const sc = getScroller();
      const y = Math.max(0, parseInt(data.y, 10) || 0);

      const doIt = () => {
        if (sc) sc.scrollTop = y;
        else window.scrollTo(0, y);
      };

      // multiple attempts to beat layout shifts
      doIt();
      setTimeout(doIt, 0);
      setTimeout(doIt, 50);
      setTimeout(doIt, 200);
      setTimeout(() => { doIt(); sessionStorage.removeItem(KEY); }, 600);
    } catch (e) {}
  }

  // Save before navigation/submission
  document.addEventListener("submit", () => saveScroll(), true);
  document.addEventListener("click", (e) => {
    const btn = e.target && e.target.closest ? e.target.closest('button, input[type="submit"], a') : null;
    if (!btn) return;
    // only save on actions likely to navigate / submit
    if (btn.tagName === "A" || btn.type === "submit" || btn.getAttribute("type") === "submit") saveScroll();
  }, true);
  window.addEventListener("beforeunload", () => saveScroll());

  // Restore on load + bfcache
  window.addEventListener("load", () => restoreScroll());
  window.addEventListener("pageshow", () => restoreScroll());
})();
</script>
