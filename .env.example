APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# PDF Splitter tool paths (defaults use system PATH)
# On Windows, set full paths e.g. "C:/Program Files/qpdf 12.2.0/bin/qpdf.exe"
# On Linux, leave as default or set e.g. "/usr/bin/qpdf"
SPLITTER_QPDF_PATH=qpdf
SPLITTER_PDFTOPPM_PATH=pdftoppm
SPLITTER_PDFUNITE_PATH=pdfunite
SPLITTER_TESSERACT_PATH=tesseract

# Property24 Alert Email Import (IMAP)
P24_IMAP_HOST=mail.hfcoastal.co.za
P24_IMAP_PORT=993
P24_IMAP_ENCRYPTION=ssl
P24_IMAP_USERNAME=sales@hfcoastal.co.za
P24_IMAP_PASSWORD=
P24_IMAP_FOLDER=INBOX
P24_IMPORT_ENABLED=true

# Puppeteer browser path for PDF generation (html-to-pdf.mjs)
# On Linux: /usr/bin/chromium-browser or /usr/bin/chromium
# On Windows: leave blank (auto-detects Microsoft Edge)
PUPPETEER_BROWSER_PATH=

# Private Property Portal Syndication
PP_USERNAME=
PP_PASSWORD=
PP_BRANCH_GUID=
PP_WSDL=https://services.sandbox.pp.co.za/AgentImport/AgentImport.asmx?WSDL
PP_SANDBOX=true

# Property24 ExDev Syndication (Outbound)
P24_EXDEV_API_URL=https://api.exdev.property24-test.com
P24_EXDEV_USERNAME=
P24_EXDEV_PASSWORD=
P24_EXDEV_AGENCY_ID=
P24_EXDEV_SANDBOX=true
P24_EXDEV_IMAGE_BASE_URL=https://corex.hfcoastal.co.za

# Meta (Facebook/Instagram) Marketing Integration
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/corex/social/oauth/callback

# Wrapper script for PDF generation on server (runs via sudo)
# Set to the full path of the wrapper, e.g. /usr/local/bin/generate-pdf.sh
# Leave blank for local dev (uses node directly)
PDF_NODE_WRAPPER=
PP_WEBHOOK_SECRET=

# Firebase Cloud Messaging (FCM v1) — used by App\Services\Push\FcmService
# FIREBASE_CREDENTIALS must point to the service account JSON file (absolute path).
FIREBASE_PROJECT=app
FIREBASE_CREDENTIALS=

# Whistleblower compliance reporting
# When PPRA_LIVE_SEND=false: emails route to DEMO_RECIPIENT
# with [DEMO] subject prefix. Production emails to PPRA only
# when set to true (post-lawyer-review).
WHISTLEBLOW_PPRA_LIVE_SEND=false
WHISTLEBLOW_DEMO_RECIPIENT=johan@hfcoastal.co.za

