{
  "manifest_version": 3,
  "name": "CoreX Portal Capture",
  "version": "2.0.0",
  "description": "Capture P24 and Private Property listings for CoreX OS",
  "permissions": ["activeTab", "storage", "notifications"],
  "host_permissions": [
    "https://www.property24.com/*",
    "https://www.privateproperty.co.za/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.property24.com/*"],
      "js": ["content-p24.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.privateproperty.co.za/*"],
      "js": ["content-pp.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
